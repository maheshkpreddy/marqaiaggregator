// Marq AI Aggregator — Prisma schema (PostgreSQL variant)
//
// This is the schema used in production (Vercel + Postgres).
// It mirrors prisma/schema.prisma (SQLite) — keep the two in sync when you
// change models. The Vercel build script (vercel-build.sh) swaps this file
// in before running `prisma generate` and `prisma db push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  apiEndpoint String?
  apiKey      String?
  models      String
  active      Boolean  @default(true)
  priority    Int      @default(0)
  color       String   @default("#64748b")
  icon        String   @default("bot")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages       Message[]
  healthLogs     HealthLog[]
  failoversFrom  FailoverLog[] @relation("FailoverFrom")
  failoversTo    FailoverLog[] @relation("FailoverTo")
  agentSteps     AgentStep[]
}

model HealthLog {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status      String
  latencyMs   Int?
  error       String?
  checkedAt   DateTime @default(now())

  @@index([providerId, checkedAt])
}

model ChatSession {
  id          String   @id @default(cuid())
  title       String   @default("New Conversation")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
}

model Message {
  id                 String     @id @default(cuid())
  sessionId          String
  session            ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role               String
  content            String
  providerId         String?
  provider           Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  model              String?
  latencyMs          Int?
  tokensUsed         Int?
  failedOver         Boolean    @default(false)
  originalProviderId String?
  createdAt          DateTime   @default(now())

  @@index([sessionId, createdAt])
}

model FailoverLog {
  id              String   @id @default(cuid())
  fromProviderId  String
  fromProvider    Provider @relation("FailoverFrom", fields: [fromProviderId], references: [id], onDelete: Cascade)
  toProviderId    String
  toProvider      Provider @relation("FailoverTo", fields: [toProviderId], references: [id], onDelete: Cascade)
  reason          String
  errorMessage    String?
  sessionId       String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Agent module
// ─────────────────────────────────────────────────────────────

model AgentTask {
  id                String   @id @default(cuid())
  title             String
  goal              String
  agentType         String   @default("general")
  status            String   @default("pending")
  maxSteps          Int      @default(8)
  primaryProviderId String?
  finalAnswer       String?
  errorMessage      String?
  totalLatencyMs    Int?
  totalTokensUsed   Int?
  failedOverCount   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps             AgentStep[]

  @@index([createdAt])
  @@index([status])
  @@index([agentType])
}

model AgentStep {
  id              String    @id @default(cuid())
  taskId          String
  task            AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepNumber      Int
  thought         String?
  action          String?
  actionInput     String?
  observation     String?
  providerId      String?
  provider        Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  model           String?
  latencyMs       Int?
  tokensUsed      Int?
  failedOver      Boolean   @default(false)
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([taskId, stepNumber])
}
