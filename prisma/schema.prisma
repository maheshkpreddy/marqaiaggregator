// Marq AI Aggregator — Prisma schema (SQLite variant, used in local dev)
//
// In production (Vercel), prisma/schema.postgres.prisma is used instead.
// The vercel-build.sh script handles swapping the schema file in before
// `prisma generate` runs. Keep this file and schema.postgres.prisma in sync
// whenever you change models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// SaaS / Multi-tenant layer
// ─────────────────────────────────────────────────────────────
// An Organization is a tenant (a company subscribing to Marq AI).
// Every chat session, agent task, prompt, file, and API key belongs to an
// Organization so that data is strictly isolated between customers.
//
// Users belong to one or more Organizations via Memberships, with a role
// (owner | admin | member | viewer) that gates what they can do.

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  plan            String   @default("free") // free | pro | enterprise
  seatsTotal      Int      @default(5)
  seatsUsed       Int      @default(0)
  // ── Super-admin approval workflow ──
  // pending_approval — just registered, awaiting super admin review
  // approved         — super admin approved, full app access
  // rejected         — super admin rejected, login blocked with reason
  // suspended        — temporarily blocked by super admin (e.g. billing issue)
  status          String   @default("pending_approval")
  rejectionReason String?
  // Linked to the user who registered the org (the owner). Useful for the
  // super admin's "pending approvals" queue.
  registeredBy    String?
  // Free-text note the super admin can attach to the tenant (e.g. "VIP customer").
  adminNote       String?
  // When the super admin last changed the plan/status.
  planAssignedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships     Membership[]
  sessions        ChatSession[]
  agentTasks      AgentTask[]
  failoverLogs    FailoverLog[]
  prompts         Prompt[]
  files           FileUpload[]
  apiKeys         ApiKey[]
  comparisonRuns  ComparisonRun[]
  customApis      CustomApiConfig[]
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String
  // Global role: "user" (default) or "super_admin". Super admins bypass
  // org-scoped RBAC and get access to the Super Admin console.
  globalRole      String   @default("user")
  // Super admin can suspend a user globally (blocks login).
  suspendedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships     Membership[]
  sessions        AuthSession[]
  chatSessions    ChatSession[]
}

// ─────────────────────────────────────────────────────────────
// Subscription plan catalog (managed by super admin)
// ─────────────────────────────────────────────────────────────
// Each plan defines a pricing tier (free / pro / enterprise / custom).
// Super admins can edit the limits per plan; orgs are assigned to a plan
// during the approval workflow. The Organization.plan field references
// SubscriptionPlan.code.
model SubscriptionPlan {
  id              String   @id @default(cuid())
  code            String   @unique // free | starter | pro | enterprise | custom
  name            String
  description     String?
  // Monthly price in USD cents (0 = free). Display only — billing is external.
  priceMonthlyUsd Int      @default(0)
  seatsIncluded   Int      @default(5)
  // Monthly request cap across all providers. 0 = unlimited.
  requestsPerMonth Int     @default(0)
  // CSV of allowed feature flags: chat,compare,agents,custom-api,unified-ai,
  // gemini,provider-guide,analytics. Empty = all features.
  features        String   @default("chat,compare,agents,custom-api")
  // Whether new signups can self-select this plan (vs. super-admin-only).
  publicVisible   Boolean  @default(true)
  // Display ordering in the pricing matrix.
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Membership {
  id              String   @id @default(cuid())
  userId          String
  orgId           String
  role            String   @default("member") // owner | admin | member | viewer
  createdAt       DateTime @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model AuthSession {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id              String   @id @default(cuid())
  orgId           String
  name            String
  keyPrefix       String   // first 12 chars of the key, shown in UI
  keyHash         String   @unique // SHA-256 hash of the full key
  scopes          String   @default("chat,compare,agents") // CSV: chat,compare,agents,read,admin,custom
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  revokedAt       DateTime?

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customApis      CustomApiConfig[]

  @@index([orgId])
}

model Prompt {
  id              String   @id @default(cuid())
  orgId           String
  title           String
  body            String
  category        String   @default("general")
  tags            String   @default("") // CSV
  createdBy       String?  // user id (best-effort, not enforced FK)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
}

model FileUpload {
  id              String   @id @default(cuid())
  orgId           String
  filename        String
  contentType     String
  sizeBytes       Int
  storageKey      String   // path/key under uploads/
  uploadedBy      String?  // user id
  createdAt       DateTime @default(now())

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

model ComparisonRun {
  id              String   @id @default(cuid())
  orgId           String
  prompt          String
  providerIds     String   // JSON array of provider IDs that were compared
  results         String   // JSON array of per-provider results
  createdAt       DateTime @default(now())

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Custom API Builder
// ─────────────────────────────────────────────────────────────
// A CustomApiConfig links an API key to an ordered subset of providers.
// The user describes a requirement in natural language; the AI picks a
// small chain of providers (open-source first, paid as fallback) and
// generates a unified API key scoped to that chain. Calls to the custom
// invoke endpoint route ONLY through the configured providers, giving
// faster, more reliable output than the full 30+ provider failover chain.

model CustomApiConfig {
  id              String   @id @default(cuid())
  orgId           String
  apiKeyId        String
  name            String
  description     String?                  // the natural-language requirement
  // JSON array of provider IDs in failover order (index 0 = primary).
  providerIds     String
  // If true, apply reorderProvidersOpenSourceFirst on top of providerIds.
  openSourceFirst Boolean  @default(true)
  // JSON map of { providerId: modelId } for model pinning. Optional.
  modelOverrides  String?
  // AI-generated rationale for the provider selection (shown in UI).
  rationale       String?
  // Per-request timeout in ms (default 12000 — shorter than the global
  // 18s to keep custom APIs fast).
  timeoutMs       Int      @default(12000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  apiKey          ApiKey       @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([apiKeyId])
}

// ─────────────────────────────────────────────────────────────
// Provider registry
// ─────────────────────────────────────────────────────────────

model Provider {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  apiEndpoint String?
  apiKey      String?
  models      String
  active      Boolean  @default(true)
  priority    Int      @default(0)
  color       String   @default("#64748b")
  icon        String   @default("bot")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages       Message[]
  healthLogs     HealthLog[]
  failoversFrom  FailoverLog[] @relation("FailoverFrom")
  failoversTo    FailoverLog[] @relation("FailoverTo")
  agentSteps     AgentStep[]
}

model HealthLog {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status      String
  latencyMs   Int?
  error       String?
  checkedAt   DateTime @default(now())

  @@index([providerId, checkedAt])
}

model ChatSession {
  id          String   @id @default(cuid())
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // The user who created/owns this session. Nullable for backward compat
  // with sessions created before this field was added.
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  title       String   @default("New Conversation")
  // When non-null, this session is an agent chat (multi-turn ReAct loop)
  // driven by the persona identified by agentType. When null, it's a
  // regular chat session (direct LLM call, no tools).
  agentType   String?
  // Soft-delete: when set, the session is hidden from the owning user's
  // sidebar but remains visible to org owners (super admin) for audit.
  deletedAt   DateTime?
  deletedBy   String?  // userId of who soft-deleted the session
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]

  @@index([orgId, agentType, updatedAt])
  @@index([userId, orgId, deletedAt, updatedAt])
  @@index([orgId, deletedAt, updatedAt])
}

model Message {
  id                 String     @id @default(cuid())
  sessionId          String
  session            ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role               String
  content            String
  providerId         String?
  provider           Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  model              String?
  latencyMs          Int?
  tokensUsed         Int?
  failedOver         Boolean    @default(false)
  originalProviderId String?
  // For agent messages: JSON-serialized ReAct step trace so the UI can
  // render the "show steps" expander under each assistant bubble.
  agentSteps         String?
  createdAt          DateTime   @default(now())

  @@index([sessionId, createdAt])
}

model FailoverLog {
  id              String   @id @default(cuid())
  orgId           String?
  org             Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  fromProviderId  String
  fromProvider    Provider @relation("FailoverFrom", fields: [fromProviderId], references: [id], onDelete: Cascade)
  toProviderId    String
  toProvider      Provider @relation("FailoverTo", fields: [toProviderId], references: [id], onDelete: Cascade)
  reason          String
  errorMessage    String?
  sessionId       String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([orgId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Agent module
// ─────────────────────────────────────────────────────────────

model AgentTask {
  id                String   @id @default(cuid())
  orgId             String?
  org               Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title             String
  goal              String
  agentType         String   @default("general")
  status            String   @default("pending")
  maxSteps          Int      @default(8)
  primaryProviderId String?
  finalAnswer       String?
  errorMessage      String?
  totalLatencyMs    Int?
  totalTokensUsed   Int?
  failedOverCount   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps             AgentStep[]

  @@index([createdAt])
  @@index([status])
  @@index([agentType])
  @@index([orgId, createdAt])
}

model AgentStep {
  id              String    @id @default(cuid())
  taskId          String
  task            AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepNumber      Int
  thought         String?
  action          String?
  actionInput     String?
  observation     String?
  providerId      String?
  provider        Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  model           String?
  latencyMs       Int?
  tokensUsed      Int?
  failedOver      Boolean   @default(false)
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([taskId, stepNumber])
}
