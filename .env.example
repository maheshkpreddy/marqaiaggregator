# Copy this file to .env (local dev) or set these in your Vercel project settings.
# This file is safe to commit; .env itself is gitignored.

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
# Local dev: SQLite path (provider is hardcoded to "sqlite" in
#   prisma/schema.prisma for local dev).
# Vercel prod: a postgres:// connection string. The vercel-build.sh
#   script swaps in prisma/schema.postgres.prisma before `prisma generate`.
DATABASE_URL="file:./db/custom.db"

# ─────────────────────────────────────────────────────────────
# Optional: z-ai-web-dev-sdk
# ─────────────────────────────────────────────────────────────
# Used by the "demo mode" fallback in src/lib/providers.ts when a
# provider has no real API key configured. Safe to leave blank in
# production if you set real provider API keys via the Providers UI.
ZAI_API_KEY=""
